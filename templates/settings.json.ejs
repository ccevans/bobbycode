      {
        "matcher": "bobby-test",
        "hooks": [
          {
            "type": "command",
            "command": "hooks/pretest.sh",
            "timeout": 30000
          }
        ]
      }
    ],
<% } %>
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "hooks/precompact.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "hooks/stop.sh"
          }
        ]
      }
    ]
  }
}
